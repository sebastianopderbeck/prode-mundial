// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - stores user authentication and profile data
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String?      // Null for OAuth users
  googleId      String?      @unique
  name          String
  isAdmin       Boolean      @default(false)
  totalScore    Int          @default(0)
  predictions   Prediction[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Match model - stores World Cup match information
model Match {
  id            String       @id @default(uuid())
  homeTeam      String
  awayTeam      String
  homeScore     Int?         // Null until match finishes
  awayScore     Int?         // Null until match finishes
  matchDate     DateTime
  deadline      DateTime     // Equal to matchDate
  status        MatchStatus  @default(PENDING)
  externalId    String?      @unique // ID from external API
  predictions   Prediction[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Match status enum
enum MatchStatus {
  PENDING
  IN_PROGRESS
  FINISHED
}

// Prediction model - stores user predictions for matches
model Prediction {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId       String
  match         Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore     Int
  awayScore     Int
  pointsEarned  Int?         // Null until match finishes
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([userId, matchId]) // One prediction per user per match
}

// SchedulerConfig model - stores configuration for automated sync jobs
model SchedulerConfig {
  id            String       @id @default(uuid())
  cronExpression String      @default("0 0 * * *") // Daily at midnight
  isActive      Boolean      @default(true)
  worldCupStart DateTime
  worldCupEnd   DateTime
  updatedAt     DateTime     @updatedAt
}
